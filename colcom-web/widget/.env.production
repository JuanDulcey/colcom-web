# Variables para el build de producción (npm run build).
#
# En Docker: este archivo es sobreescrito por el ARG VITE_API_BASE_URL
# del Dockerfile — no necesitas modificarlo para builds Docker.
#
# Para despliegue en AWS / Azure: cambia esta URL por la del backend en la nube.

VITE_API_BASE_URL=https://ingenelsong-latinoamerica-comparte-api.hf.space